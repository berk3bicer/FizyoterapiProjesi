@page
@model HakkimdaModel
@{
    ViewData["Title"] = "Hakkımda";
}

<!-- A) SAYFA HERO -->
<section class="hakkimda-hero">
    <div class="hero-blob hero-blob-1"></div>
    <div class="hero-blob hero-blob-2"></div>
    <div class="container hakkimda-hero-content">
        <span class="section-tag">Tanışın</span>
        @if (Model.Therapist != null)
        {
            <h1 class="hakkimda-hero-title">@Model.Therapist.FullName</h1>
            <p class="hakkimda-hero-role">@Model.Therapist.Title</p>
            <p class="hakkimda-hero-intro">
                @(Model.Therapist.Biography?.Split('.').FirstOrDefault()?.Trim() + ".")
            </p>
        }
        else
        {
            <h1 class="hakkimda-hero-title">Profesyonel Fizyoterapi</h1>
            <p class="hakkimda-hero-role">Uzman Fizyoterapist</p>
            <p class="hakkimda-hero-intro">Modern fizyoterapi anlayışıyla hastalarımızın sağlığına kavuşmasına yardımcı oluyoruz.</p>
        }
    </div>
</section>

<!-- B) BİLGİ SÜTUNLARI -->
<section class="hakkimda-info-section bg-cream">
    <div class="container">
        <div class="row align-items-start g-5">
            <div class="col-lg-5">
                <div class="about-image-wrapper">
                    <div class="about-blob"></div>
                    <div class="about-image">
                        @if (Model.Therapist != null)
                        {
                            <span class="about-initial">@(Model.Therapist.FullName?.Substring(0, 1) ?? "F")</span>
                        }
                        else
                        {
                            <span class="about-initial">F</span>
                        }
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                @if (Model.Therapist != null)
                {
                    <h2 class="about-title">Biyografi</h2>
                    <p class="about-bio">@Model.Therapist.Biography</p>

                    <div class="info-icon-row">
                        <div class="info-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                                <path d="M6 12v5c3 3 9 3 12 0v-5"/>
                            </svg>
                        </div>
                        <div>
                            <span class="info-label">Eğitim</span>
                            <span class="info-value">@Model.Therapist.Education</span>
                        </div>
                    </div>

                    <div class="spec-section">
                        <span class="info-label">Uzmanlık Alanları</span>
                        <div class="spec-badges">
                            @foreach (var spec in (Model.Therapist.Specializations ?? "").Split(','))
                            {
                                if (!string.IsNullOrWhiteSpace(spec))
                                {
                                    <span class="spec-badge">@spec.Trim()</span>
                                }
                            }
                        </div>
                    </div>

                    <div class="info-icon-row">
                        <div class="info-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect width="20" height="16" x="2" y="4" rx="2"/>
                                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                            </svg>
                        </div>
                        <div>
                            <span class="info-label">E-posta</span>
                            <span class="info-value">@Model.Therapist.Email</span>
                        </div>
                    </div>

                    <div class="info-icon-row">
                        <div class="info-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.61 4.38 2 2 0 0 1 3.58 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.18 6.18l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                            </svg>
                        </div>
                        <div>
                            <span class="info-label">Telefon</span>
                            <span class="info-value">@Model.Therapist.Phone</span>
                        </div>
                    </div>
                }
                else
                {
                    <h2 class="about-title">Profesyonel Fizyoterapi Hizmeti</h2>
                    <p class="about-bio">Modern fizyoterapi anlayışıyla, kişiye özel tedavi planları sunarak hastalarımızın sağlığına kavuşmasına yardımcı oluyoruz.</p>
                }
            </div>
        </div>
    </div>
</section>

<!-- C) YAKLAŞIMIM -->
<section class="why-us-section">
    <div class="container">
        <div class="section-title">
            <span class="section-tag">Yaklaşımım</span>
            <h2>Tedaviye Bakış Açım</h2>
            <p>Her hastama gösterdiğim özen ve benimsediğim ilkeler</p>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-lg-4 col-md-6">
                <div class="why-card">
                    <div class="why-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                        </svg>
                    </div>
                    <h3>Hasta Odaklı Yaklaşım</h3>
                    <p>Her hastamı dikkatle dinler, bireysel ihtiyaçlarını anlamaya çalışır ve tedaviyi buna göre şekillendiririm.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="why-card">
                    <div class="why-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                        </svg>
                    </div>
                    <h3>Sürekli Gelişim</h3>
                    <p>Güncel bilimsel literatürü yakından takip eder, mesleki gelişimime yatırım yaparak hastalarıma en iyi hizmeti sunarım.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="why-card">
                    <div class="why-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/>
                            <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
                            <path d="M2 12h20"/>
                        </svg>
                    </div>
                    <h3>Bütüncül Bakış</h3>
                    <p>Fiziksel iyileşmenin yanı sıra duygusal refahı da göz önünde bulundurur, kişinin tümünü ele alarak tedavi planlarım.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- D) CTA -->
<section class="cta-section">
    <div class="container">
        <div class="cta-card">
            <h2>Birlikte Sağlıklı Bir Başlangıç Yapalım</h2>
            <p>İlk adımı atmak için randevu alın, size özel bir tedavi planı hazırlayalım</p>
            <a href="/Randevu" class="btn-cta">Randevu Al</a>
        </div>
    </div>
</section>
