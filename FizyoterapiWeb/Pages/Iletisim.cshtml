@page
@model IletisimModel
@{
    ViewData["Title"] = "İletişim";
}

<section class="py-5" style="background: linear-gradient(135deg, #5a8a7a 0%, #3d6b5d 100%);">
    <div class="container text-center text-white py-4">
        <h1 class="display-5 fw-bold">İletişim</h1>
        <p class="lead">Bize ulaşın, size en kısa sürede dönüş yapalım</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4 justify-content-center">
            @if (Model.Therapist != null)
            {
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100 text-center">
                        <div class="card-body p-4">
                            <div class="display-4 mb-3">📧</div>
                            <h5 class="fw-bold">E-posta</h5>
                            <p class="text-muted">@Model.Therapist.Email</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100 text-center">
                        <div class="card-body p-4">
                            <div class="display-4 mb-3">📞</div>
                            <h5 class="fw-bold">Telefon</h5>
                            <p class="text-muted">@Model.Therapist.Phone</p>
                        </div>
                    </div>
                </div>
            }

            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center">
                    <div class="card-body p-4">
                        <div class="display-4 mb-3">📍</div>
                        <h5 class="fw-bold">Adres</h5>
                        <p class="text-muted">İstanbul, Türkiye</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center mt-5">
            <p class="lead">Online randevu için</p>
            <a href="/Randevu" class="btn btn-success btn-lg">Randevu Al</a>
        </div>
    </div>
</section>